APP_NAME="Scout Laravel POC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8088

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=scout
DB_USERNAME=scout
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@scout-poc.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

APP_PORT=8088
FORWARD_DB_PORT=33060
FORWARD_REDIS_PORT=63790
FORWARD_MAILPIT_PORT=8025
FORWARD_MAILPIT_SMTP_PORT=1025

# Scout APM agent (scoutapp/scout-apm-php)
SCOUT_KEY=
SCOUT_NAME="${APP_NAME}"
SCOUT_MONITOR=true
SCOUT_LOG_LEVEL=debug
SCOUT_CORE_AGENT_LAUNCH=true
SCOUT_CORE_AGENT_DOWNLOAD=true

# Obeserva (scout/laravel from github.com/zaeem2396/laravel-obeserva)
OBESERVA_ENABLED=true
OBESERVA_DRIVER=scout
OBESERVA_SCOUT_MONITORING_ENABLED=true
OBESERVA_SCOUT_APPLICATION_NAME="${APP_NAME}"
OBESERVA_DEBUG_TOOLBAR=true
OBESERVA_CORRELATION_ENABLED=true
# With OBESERVA_DRIVER=scout, leave these false so scout-apm-php owns HTTP/SQL spans (required for N+1 Insights).
OBESERVA_HTTP_MIDDLEWARE=false
OBESERVA_DB_QUERY_TRACING=false
OBESERVA_FLUSH_ON_TERMINATE=false
SCOUT_MONITORING_ENABLED=true
